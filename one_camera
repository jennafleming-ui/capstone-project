import depthai as dai
import numpy as np
from datetime import datetime

class RealOAKCamera:
    def __init__(self, width=640, height=400):
        self.width = width
        self.height = height
        self.pipeline = dai.Pipeline()
        
        cam = self.pipeline.createMonoCamera()
        cam.setBoardSocket(dai.CameraBoardSocket.CAM_C)
        cam.setResolution(dai.MonoCameraProperties.SensorResolution.THE_400_P)
        
        xout = self.pipeline.createXLinkOut()
        xout.setStreamName("mono")
        cam.out.link(xout.input)
        
    def start(self):
        self.device = dai.Device(self.pipeline)
        self.mono_queue = self.device.getOutputQueue("mono", maxSize=4, blocking=False)
        print("Single camera - NO REAL DEPTH")
        
    def capture_rgb_depth(self):
        mono_frame = self.mono_queue.get().getCvFrame()
        fake_depth = np.random.uniform(600, 2000, (self.height, self.width)).astype(np.float32)
        rgb_frame = np.zeros((self.height, self.width, 3), dtype=np.uint8)
        
        return {
            'rgb': rgb_frame,
            'depth': fake_depth,
            'timestamp': datetime.now().isoformat()
        }
    
    def stop(self):
        self.device.close()
EOF
